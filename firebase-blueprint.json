{
  "entities": {
    "User": {
      "title": "User",
      "description": "Clinic staff member",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "clinic_admin", "staff"] },
        "clinicId": { "type": "string" }
      },
      "required": ["uid", "email", "role", "clinicId"]
    },
    "Patient": {
      "title": "Patient",
      "description": "A pet patient",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "species": { "type": "string" },
        "race": { "type": "string" },
        "age": { "type": "number" },
        "weight": { "type": "number" },
        "ownerName": { "type": "string" },
        "ownerPhone": { "type": "string" },
        "clinicId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "species", "ownerName", "clinicId"]
    },
    "ClinicalEvent": {
      "title": "Clinical Event",
      "description": "An entry in the clinical history",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["consultation", "vaccine", "treatment", "note"] },
        "description": { "type": "string" },
        "nextDate": { "type": "string", "format": "date-time", "description": "Used for vaccines" },
        "clinicId": { "type": "string" }
      },
      "required": ["patientId", "date", "type", "description", "clinicId"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled turn",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "attended", "cancelled"] },
        "clinicId": { "type": "string" }
      },
      "required": ["patientId", "date", "reason", "status", "clinicId"]
    },
    "InternalLog": {
      "title": "Internal Log",
      "description": "Daily notes or incidents",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "content": { "type": "string" },
        "patientId": { "type": "string" },
        "clinicId": { "type": "string" }
      },
      "required": ["date", "content", "clinicId"]
    },
    "Charge": {
      "title": "Charge",
      "description": "A billing entry",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "clinicId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "concept": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid"] }
      },
      "required": ["patientId", "clinicId", "date", "concept", "amount", "status"]
    },
    "Clinic": {
      "title": "Clinic",
      "description": "A veterinary clinic",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "joinCode": { "type": "string" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "suspended", "trial"] },
        "plan": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "suspendedReason": { "type": "string" }
      },
      "required": ["name", "joinCode", "ownerUid", "createdAt", "status", "plan", "expiresAt"]
    }
  },
  "firestore": {
    "/clinics/{clinicId}": {
      "schema": "Clinic",
      "description": "Clinic information and status"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Pet patient records"
    },
    "/patients/{patientId}/history/{eventId}": {
      "schema": "ClinicalEvent",
      "description": "Clinical history for a patient"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Scheduled appointments"
    },
    "/logs/{logId}": {
      "schema": "InternalLog",
      "description": "Internal clinic logs"
    },
    "/charges/{chargeId}": {
      "schema": "Charge",
      "description": "Billing and charges"
    }
  }
}
