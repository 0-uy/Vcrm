// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: clinics
// Document ID: {clinicId}
// Fields:
//   - name: string
//   - joinCode: string (6 chars)
//   - ownerUid: string
//   - createdAt: timestamp
//   - status: string (enum: ['active', 'suspended', 'trial'])
//   - plan: string
//   - expiresAt: timestamp
//   - suspendedReason: string (optional)
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string (required, email format)
//   - displayName: string (optional)
//   - role: string (required, enum: ['superadmin', 'clinic_admin', 'staff'])
//   - clinicId: string (required)
//
// Collection: patients
// Document ID: {patientId}
// Fields:
//   - name: string (required)
//   - species: string (required)
//   - race: string (optional)
//   - age: number (optional)
//   - weight: number (optional)
//   - ownerName: string (required)
//   - ownerPhone: string (optional)
//   - clinicId: string (required)
//   - createdAt: timestamp (required)
//   - lastVisitAt: timestamp (optional)
//
// Collection: activity
// Document ID: {activityId}
// Fields:
//   - date: timestamp
//   - type: string
//   - description: string
//   - patientId: string (optional)
//   - patientName: string (optional)
//   - clinicId: string
//   - userName: string
//
// Collection: inventory
// Document ID: {itemId}
// Fields:
//   - name: string
//   - stock: number
//   - minStock: number
//   - clinicId: string
//   - updatedAt: timestamp
//
// Collection: vaccines
// Document ID: {vaccineId}
// Fields:
//   - patientId: string
//   - patientName: string
//   - clinicId: string
//   - type: string
//   - date: timestamp
//   - nextDate: timestamp
//   - status: string
//
// Collection: charges
// Document ID: {chargeId}
// Fields:
//   - patientId: string
//   - patientName: string
//   - clinicId: string
//   - date: timestamp
//   - concept: string
//   - amount: number
//   - status: string (enum: ['pending', 'paid'])
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"role": "guest", "clinicId": ""};
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isClinicMember(clinicId) {
      return isSuperAdmin() || (isAuthenticated() && userExists() && getUserData().clinicId == clinicId);
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
             (
               (request.auth.token.email == "imcorreamauricio@gmail.com" && request.auth.token.email_verified == true) ||
               (request.auth.token.email == "chocolatescomferre@gmail.com" && request.auth.token.email_verified == true) ||
               (userExists() && "role" in getUserData() && getUserData().role == "superadmin")
             );
    }

    function isClinicAdmin() {
      return isSuperAdmin() || (isAuthenticated() && userExists() && getUserData().role == "clinic_admin");
    }

    function isClinicActive(clinicId) {
      return isSuperAdmin() || (exists(/databases/$(database)/documents/clinics/$(clinicId)) && get(/databases/$(database)/documents/clinics/$(clinicId)).data.status in ['active', 'trial']);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidEmail(email) {
      return email is string && email.matches(".+@.+\\..+");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidClinic(data) {
      return data.name is string && data.name.size() > 0 &&
             data.joinCode is string && data.joinCode.size() == 6 &&
             data.ownerUid is string &&
             data.createdAt is timestamp &&
             data.status in ['active', 'suspended', 'trial'] &&
             data.plan is string &&
             data.expiresAt is timestamp;
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string && isValidEmail(data.email) &&
             (!('role' in data) || data.role in ['superadmin', 'clinic_admin', 'staff']) &&
             (!('clinicId' in data) || data.clinicId is string);
    }

    function isValidPatient(data) {
      return data.name is string && data.name.size() > 0 &&
             data.species is string &&
             data.ownerName is string &&
             data.clinicId is string &&
             (data.createdAt is timestamp || data.createdAt is string);
    }

    function isValidClinicalEvent(data) {
      return data.patientId is string &&
             data.date is timestamp &&
             data.type in ['consultation', 'vaccine', 'treatment', 'note'] &&
             data.description is string && data.description.size() < 5000 &&
             data.clinicId is string &&
             (!('patientName' in data) || data.patientName is string) &&
             (!('nextDate' in data) || data.nextDate is timestamp);
    }

    function isValidActivity(data) {
      return data.date is timestamp &&
             data.type is string &&
             data.description is string &&
             data.clinicId is string;
    }

    function isValidVaccine(data) {
      return data.patientId is string &&
             data.clinicId is string &&
             data.date is timestamp &&
             data.nextDate is timestamp;
    }

    function isValidInventory(data) {
      return data.name is string && data.name.size() > 0 &&
             data.stock is number &&
             data.minStock is number &&
             data.clinicId is string &&
             data.updatedAt is timestamp;
    }

    function isValidAppointment(data) {
      return data.patientId is string &&
             data.patientName is string &&
             data.date is timestamp &&
             data.reason is string &&
             data.status in ['pending', 'in-consultation', 'attended', 'cancelled'] &&
             data.clinicId is string &&
             (!('isHomeVisit' in data) || data.isHomeVisit is bool);
    }

    function isValidLog(data) {
      return data.date is timestamp &&
             data.content is string && data.content.size() < 5000 &&
             data.clinicId is string;
    }

    function isValidCharge(data) {
      return data.patientId is string &&
             data.patientName is string &&
             data.clinicId is string &&
             data.date is timestamp &&
             data.concept is string && data.concept.size() > 0 &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'paid'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /clinics/{clinicId} {
      allow read: if isAuthenticated(); // Needed to check joinCode and status
      allow create: if isAuthenticated() && isValidClinic(request.resource.data);
      allow update: if isSuperAdmin() || (isAuthenticated() && isClinicMember(clinicId) && isClinicAdmin() && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'plan', 'expiresAt', 'suspendedReason']));
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || (userExists() && getUserData().clinicId == resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /patients/{patientId} {
      allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && isValidPatient(request.resource.data) && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
      allow update: if isAuthenticated() && isValidPatient(request.resource.data) && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId) &&
                    request.resource.data.clinicId == resource.data.clinicId;
      allow delete: if isClinicAdmin() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);

      match /history/{eventId} {
        allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
        allow create: if isAuthenticated() && isValidClinicalEvent(request.resource.data) && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
        allow update: if isAuthenticated() && isValidClinicalEvent(request.resource.data) && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
        allow delete: if isClinicAdmin() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
      }
    }

    match /activity/{activityId} {
      allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && isValidActivity(request.resource.data) && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
    }

    match /vaccines/{vaccineId} {
      allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && isValidVaccine(request.resource.data) && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
      allow update: if isAuthenticated() && isValidVaccine(request.resource.data) && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
      allow delete: if isClinicAdmin() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && isValidInventory(request.resource.data) && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
      allow update: if isAuthenticated() && isValidInventory(request.resource.data) && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
      allow delete: if isClinicAdmin() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && isValidAppointment(request.resource.data) && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
      allow update: if isAuthenticated() && isValidAppointment(request.resource.data) && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
      allow delete: if isClinicAdmin() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
    }

    match /logs/{logId} {
      allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && isValidLog(request.resource.data) && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
      allow update: if isAuthenticated() && isValidLog(request.resource.data) && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
      allow delete: if isClinicAdmin() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
    }

    match /charges/{chargeId} {
      allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && isValidCharge(request.resource.data) && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
      allow update: if isAuthenticated() && isValidCharge(request.resource.data) && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
      allow delete: if isClinicAdmin() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
    }

    match /prescriptions/{id} {
      allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
      allow update: if isAuthenticated() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
      allow delete: if isClinicAdmin() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
    }

    match /soap_notes/{id} {
      allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
      allow update: if isAuthenticated() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
      allow delete: if isClinicAdmin() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
    }

    match /attachments/{id} {
      allow read: if isAuthenticated() && (isClinicMember(resource.data.clinicId) || isSuperAdmin());
      allow create: if isAuthenticated() && isClinicMember(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId);
      allow update: if isAuthenticated() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
      allow delete: if isClinicAdmin() && isClinicMember(resource.data.clinicId) && isClinicActive(resource.data.clinicId);
    }
  }
}
